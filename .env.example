# SongForge — скопируйте в .env и заполните значения
# cp .env.example .env   (Linux)  |  copy .env.example .env   (Windows)

# --- Обязательно для генерации ---
APIPASS_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=b1gto6f1fi6j2dpfdlhd

# --- Сайт ---
SITE_URL=http://127.0.0.1:8000
# PORT=8000

# --- Оплата (пока stub) ---
PAYMENT_PROVIDER=stub
PRODAMUS_SHOP_ID=
PRODAMUS_SECRET=
# Ручная оплата в бете (пока stub): скидка и реквизиты на странице «Пакеты»
BETA_MANUAL_PAYMENT_ENABLED=true
BETA_DISCOUNT_PERCENT=50
BETA_PAYMENT_CONTACT=Telegram: @your_username
BETA_PAYMENT_DETAILS=СБП +7XXXXXXXXXX или карта Сбер 2202 XXXX XXXX XXXX

# --- Email-вход (пустой SMTP = код на экране) ---
SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# --- Telegram (когда будет бот) ---
TELEGRAM_AUTH_ENABLED=false
# TELEGRAM_BOT_TOKEN=

# --- Админ-панель (/admin) ---
# Ваш email — станет super_admin при первом открытии /admin (после входа на сайте).
ADMIN_BOOTSTRAP_EMAILS=you@example.com
# Опционально: только эти IP (через запятую). Пусто = без ограничения.
# ADMIN_IP_ALLOWLIST=195.19.20.245

# --- Безопасность продакшена (всегда false на сервере) ---
DEV_TOPUP_ENABLED=false
AUTH_DEV_CODE_ENABLED=false
LEGACY_API_ENABLED=false

# --- Опционально ---
# APIPASS_BASE=https://api.apipass.dev/api/v1/jobs
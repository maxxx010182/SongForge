# SongForge — скопируйте в .env и заполните значения
# cp .env.example .env   (Linux)  |  copy .env.example .env   (Windows)

# --- Обязательно для генерации ---
APIPASS_API_KEY=
# Запасной/второй канал Suno (https://sunoapi.org)
SUNOAPI_ORG_API_KEY=
# apipass | sunoapi | fallback (ApiPass→sunoapi) | fallback_suno (sunoapi→ApiPass)
MUSIC_PROVIDER=fallback_suno
YANDEX_API_KEY=
YANDEX_FOLDER_ID=b1gto6f1fi6j2dpfdlhd

# --- Сайт ---
SITE_URL=http://127.0.0.1:8000
# PORT=8000

# --- Оплата ---
PAYMENT_PROVIDER=getplatinum
GETPLATINUM_ACCOUNT=your_account
GETPLATINUM_API_KEY=
GETPLATINUM_VAT=none
PRODAMUS_SHOP_ID=
PRODAMUS_SECRET=

# --- Email-вход (пустой SMTP = код на экране при AUTH_DEV_CODE или без SMTP) ---
SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@sozdaipesnu.ru
# SMTP_USE_TLS=true

# --- Telegram Login Widget (бот + /setdomain в BotFather) ---
TELEGRAM_AUTH_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=YourBot

# --- VK ID OAuth (https://id.vk.com/about/business/go/docs/ru/vkid/latest) ---
VK_AUTH_ENABLED=false
# VK_APP_ID=
# VK_APP_SECRET=
# VK_AUTH_BASE=https://id.vk.ru

# --- Админ-панель (/admin) ---
# Ваш email — станет super_admin при первом открытии /admin (после входа на сайте).
ADMIN_BOOTSTRAP_EMAILS=you@example.com
# Опционально: только эти IP (через запятую). Пусто = без ограничения.
# ADMIN_IP_ALLOWLIST=195.19.20.245

# --- Безопасность продакшена (всегда false на сервере) ---
AUTH_DEV_CODE_ENABLED=false
LEGACY_API_ENABLED=false

# --- Redis (очередь + worker) ---
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
WORKER_POLL_INTERVAL_SEC=3

# --- S3 REG.RU Object Storage ---
S3_ENABLED=false
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=ru-1
# Публичный URL бакета (для play/download), например https://bucket.hb.ru-msk.vkcloud-storage.ru
S3_PUBLIC_BASE=

# --- SQLite ---
# SQLITE_TIMEOUT_SEC=30

# --- Опционально ---
# APIPASS_BASE=https://api.apipass.dev/api/v1/jobs
# SUNOAPI_ORG_BASE=https://api.sunoapi.org/api/v1